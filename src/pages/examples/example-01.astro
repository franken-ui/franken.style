---
import { stl } from "helpers/common";
import Frame from "layouts/frame.astro";
---

<Frame doc={{ title: "example-01" }}>
  <div
    class="display-hidden p lg:p xl:display-block"
    style={stl({ "--p": "6", "--lg-p": "10" })}
  >
    <div class="space-y" style={stl({ "--space-y": "0.5" })}>
      <h2 class="text-2xl font-bold tracking-tight">Settings</h2>
      <p class="color" style={stl({ "--color": "var(--uk-muted-f)" })}>
        Manage your account settings and set e-mail preferences.
      </p>
    </div>

    <div
      class="my border-t-w border-t/o"
      style={stl({
        "--my": "6",
        "--border-t-w": "1px",
        "--border-t": "var(--uk-border)",
        "--border-t-o": "var(--uk-border-o)",
      })}
    >
    </div>

    <div class="display-flex gap-x" style={stl({ "--gap-x": "12" })}>
      <aside class="[w]" style={stl({ "--w": "20%" })}>
        <ul
          class="uk-nav uk-nav-alt uk-nav-primary"
          data-uk-switcher="connect: #component-nav; animation: uk-animation-slide-left-small"
        >
          <li class="uk-active">
            <a href="#">Profile</a>
          </li>
          <li>
            <a href="#">Account</a>
          </li>
          <li>
            <a href="#">Appearance</a>
          </li>
          <li>
            <a href="#">Notifications</a>
          </li>
          <li>
            <a href="#">Display</a>
          </li>
        </ul>
      </aside>
      <div class="flex-1">
        <ul id="component-nav" class="uk-switcher max-w-2xl">
          <li class="uk-active space-y" style={stl({ "--space-y": "6" })}>
            <div>
              <h3 class="text-lg font-medium">Profile</h3>
              <p
                class="color text-sm"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                This is how others will see you on the site.
              </p>
            </div>

            <div
              class="border-t-w border-t/o"
              style={stl({
                "--border-t-w": "1px",
                "--border-t": "var(--uk-border)",
                "--border-t-o": "var(--uk-border-o)",
              })}
            >
            </div>

            <div class="space-y" style={stl({ "--space-y": "2" })}>
              <label class="display-block uk-form-label" for="username"
                >Username</label
              >
              <input
                class="uk-input"
                id="username"
                type="text"
                placeholder="reden.fm"
              />
              <div
                class="uk-form-help color"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                This is your public display name. It can be your real name or a
                pseudonym. You can only change this once every 30 days.
              </div>
            </div>

            <div class="space-y" style={stl({ "--space-y": "2" })}>
              <label class="display-block uk-form-label" for="email"
                >Email</label
              >
              <div
                class="[h]"
                style={stl({ "--h": "calc(var(--uk-global-font-size) * 2.5)" })}
              >
                <uk-select
                  cls="button: uk-input-fake justify-between w-full; dropdown: w-full"
                  icon="chevrons-up-down"
                  placeholder="Select a verified email to display"
                  insertable
                >
                  <select data-fn="data-source" hidden>
                    <option>m@example.com</option>
                    <option>m@yahoo.com</option>
                    <option>m@cloud.com</option>
                  </select>
                </uk-select>
              </div>

              <div
                class="uk-form-help color"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                You can manage verified email addresses in your email settings.
              </div>
            </div>

            <div class="space-y" style={stl({ "--space-y": "2" })}>
              <label
                class="display-block uk-form-label color"
                style={stl({ "--color": "var(--uk-danger-f)" })}
                for="bio"
              >
                Bio
              </label>
              <textarea
                class="uk-textarea uk-form-danger"
                id="bio"
                placeholder="Tell us a little bit about yourself"></textarea>
              <div
                class="uk-form-help color"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                You can @mention other users and organizations to link to them.
              </div>
              <div
                class="uk-form-help color"
                style={stl({ "--color": "var(--uk-danger-f)" })}
              >
                String must contain at least 4 character(s)
              </div>
            </div>

            <div class="space-y" style={stl({ "--space-y": "2" })}>
              <div class="uk-form-label">URLs</div>
              <div
                class="uk-form-help color"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                Add links to your website, blog, or social media profiles.
              </div>
              <input
                class="uk-input"
                readonly
                type="text"
                value="https://www.franken.style"
              />
              <input
                class="uk-input"
                readonly
                type="text"
                value="https://codeberg.org/FRNKN/style"
              />
              <button class="uk-button uk-button-default"> Add URL </button>
            </div>

            <div class="">
              <button class="uk-button uk-button-primary">
                Update profile
              </button>
            </div>
          </li>
          <li class="space-y" style={stl({ "--space-y": "6" })}>
            <div>
              <h3 class="text-lg font-medium">Account</h3>
              <p
                class="color text-sm"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                Update your account settings. Set your preferred language and
                timezone.
              </p>
            </div>

            <div
              class="border-t-w border-t/o"
              style={stl({
                "--border-t-w": "1px",
                "--border-t": "var(--uk-border)",
                "--border-t-o": "var(--uk-border-o)",
              })}
            >
            </div>

            <div class="space-y" style={stl({ "--space-y": "2" })}>
              <label class="display-block uk-form-label" for="name">Name</label>
              <input
                class="uk-input"
                id="name"
                type="text"
                placeholder="Your name"
              />
              <div
                class="uk-form-help color"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                This is the name that will be displayed on your profile and in
                emails.
              </div>
            </div>

            <div class="space-y" style={stl({ "--space-y": "2" })}>
              <label
                class="display-block uk-form-label block"
                for="date_of_birth">Date of Birth</label
              >
              <div
                class="[h] [w]"
                style={stl({
                  "--h": "calc(var(--uk-global-font-size) * 2.5)",
                  "--w": "278px",
                })}
              >
                <uk-input-date cls="uk-input-fake justify-between"
                ></uk-input-date>
              </div>

              <div
                class="uk-form-help color"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                Your date of birth is used to calculate your age.
              </div>
            </div>

            <div class="space-y" style={stl({ "--space-y": "2" })}>
              <label class="display-block uk-form-label block" for="language">
                Language
              </label>

              <div
                class="[h]"
                style={stl({ "--h": "calc(var(--uk-global-font-size) * 2.5)" })}
              >
                <uk-select
                  cls="button: uk-input-fake justify-between w-full; dropdown: w-full"
                  icon="chevrons-up-down"
                  placeholder="Select a language"
                >
                  <select data-fn="data-source" hidden>
                    <optgroup label="Select a language">
                      <option selected>English</option>
                      <option>French</option>
                      <option>German</option>
                      <option>Spanish</option>
                      <option>Portuguese</option>
                    </optgroup>
                  </select>
                </uk-select>
              </div>
              <div
                class="uk-form-help color"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                This is the language that will be used in the dashboard.
              </div>
            </div>

            <div class="">
              <button class="uk-button uk-button-primary">
                Update profile
              </button>
            </div>
          </li>
          <li class="space-y" style={stl({ "--space-y": "6" })}>
            <div>
              <h3 class="text-lg font-medium">Appearance</h3>
              <p
                class="color text-sm"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                Customize the appearance of the app. Automatically switch
                between day and night themes.
              </p>
            </div>

            <div
              class="border-t-w border-t/o"
              style={stl({
                "--border-t-w": "1px",
                "--border-t": "var(--uk-border)",
                "--border-t-o": "var(--uk-border-o)",
              })}
            >
            </div>

            <div class="space-y" style={stl({ "--space-y": "2" })}>
              <label class="display-block uk-form-label block" for="email">
                Font Family
              </label>
              <div
                class="[h]"
                style={stl({ "--h": "calc(var(--uk-global-font-size) * 2.5)" })}
              >
                <uk-select
                  cls="button: uk-input-fake justify-between w-full; dropdown: w-full"
                  icon="chevrons-up-down"
                  placeholder="Select a font family"
                >
                  <select data-fn="data-source" hidden>
                    <optgroup label="Select a font family">
                      <option>Inter</option>
                      <option selected>Geist</option>
                      <option>Open Sans</option>
                    </optgroup>
                  </select>
                </uk-select>
              </div>
              <div
                class="uk-form-help color"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                Set the font you want to use in the dashboard.
              </div>
            </div>

            <div class="space-y" style={stl({ "--space-y": "2" })}>
              <div class="uk-form-label">Theme</div>

              <div
                class="uk-form-help color"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                Select the theme for the dashboard.
              </div>

              <div
                class="display-grid max-w-md grid-cols gap"
                style={stl({ "--grid-cols": "2", "--gap": "8" })}
              >
                <uk-lsh cls="w-full" toggle group="mode">
                  <template data-fn="template">
                    <div
                      class="border-w border/o display-block cursor-pointer items-center rounded-md p"
                      style={stl({
                        "--border-w": "2px",
                        "--border": "var(--uk-border)",
                        "--border-o": "var(--uk-border-o)",
                        "--p": "1",
                      })}
                    >
                      <div
                        class="space-y rounded-sm bg p"
                        style={stl({
                          "--space-y": "2",
                          "--bg": "#ecedef",
                          "--p": "2",
                        })}
                      >
                        <div
                          class="space-y rounded-md bg p"
                          style={stl({
                            "--space-y": "2",
                            "--bg": "#fff",
                            "--p": "2",
                          })}
                        >
                          <div
                            class="h [w] rounded-lg bg"
                            style={stl({
                              "--h": "2",
                              "--w": "80px",
                              "--bg": "#ecedef",
                            })}
                          >
                          </div>
                          <div
                            class="h [w] rounded-lg bg"
                            style={stl({
                              "--h": "2",
                              "--w": "100px",
                              "--bg": "#ecedef",
                            })}
                          >
                          </div>
                        </div>
                        <div
                          class="display-flex items-center space-x rounded-md bg p shadow-sm"
                          style={stl({
                            "--space-x": "2",
                            "--bg": "#fff",
                            "--p": "2",
                          })}
                        >
                          <div
                            class="size rounded-full bg"
                            style={stl({ "--size": "4", "--bg": "#ecedef" })}
                          >
                          </div>
                          <div
                            class="h [w] rounded-lg bg"
                            style={stl({
                              "--h": "2",
                              "--w": "100px",
                              "--bg": "#ecedef",
                            })}
                          >
                          </div>
                        </div><div
                          class="display-flex items-center space-x rounded-md bg p shadow-sm"
                          style={stl({
                            "--space-x": "2",
                            "--bg": "#fff",
                            "--p": "2",
                          })}
                        >
                          <div
                            class="size rounded-full bg"
                            style={stl({ "--size": "4", "--bg": "#ecedef" })}
                          >
                          </div>
                          <div
                            class="h [w] rounded-lg bg"
                            style={stl({
                              "--h": "2",
                              "--w": "100px",
                              "--bg": "#ecedef",
                            })}
                          >
                          </div>
                        </div>
                      </div>
                    </div>
                  </template>
                </uk-lsh>
                <uk-lsh cls="w-full" toggle group="mode">
                  <template data-fn="template">
                    <div
                      class="border-w border/o display-block cursor-pointer items-center rounded-md p"
                      style={stl({
                        "--border-w": "2px",
                        "--border": "var(--uk-border)",
                        "--border-o": "var(--uk-border-o)",
                        "--p": "1",
                      })}
                    >
                      <div
                        class="space-y rounded-sm bg p"
                        style={stl({
                          "--space-y": "2",
                          "--bg": "var(--color-slate-950)",
                          "--p": "2",
                        })}
                      >
                        <div
                          class="space-y rounded-md bg p"
                          style={stl({
                            "--space-y": "2",
                            "--bg": "var(--color-slate-800)",
                            "--p": "2",
                          })}
                        >
                          <div
                            class="h [w] rounded-lg bg"
                            style={stl({
                              "--h": "2",
                              "--w": "80px",
                              "--bg": "var(--color-slate-400)",
                            })}
                          >
                          </div>
                          <div
                            class="h [w] rounded-lg bg"
                            style={stl({
                              "--h": "2",
                              "--w": "100px",
                              "--bg": "var(--color-slate-400)",
                            })}
                          >
                          </div>
                        </div>

                        <div
                          class="display-flex items-center space-x rounded-md bg p shadow-sm"
                          style={stl({
                            "--space-x": "2",
                            "--bg": "var(--color-slate-800)",
                            "--p": "2",
                          })}
                        >
                          <div
                            class="size rounded-full bg"
                            style={stl({
                              "--size": "4",
                              "--bg": "var(--color-slate-400)",
                            })}
                          >
                          </div>
                          <div
                            class="h [w] rounded-lg bg"
                            style={stl({
                              "--h": "2",
                              "--w": "100px",
                              "--bg": "var(--color-slate-400)",
                            })}
                          >
                          </div>
                        </div>

                        <div
                          class="display-flex items-center space-x rounded-md bg p shadow-sm"
                          style={stl({
                            "--space-x": "2",
                            "--bg": "var(--color-slate-800)",
                            "--p": "2",
                          })}
                        >
                          <div
                            class="size rounded-full bg"
                            style={stl({
                              "--size": "4",
                              "--bg": "var(--color-slate-400)",
                            })}
                          >
                          </div>
                          <div
                            class="h [w] rounded-lg bg"
                            style={stl({
                              "--h": "2",
                              "--w": "100px",
                              "--bg": "var(--color-slate-400)",
                            })}
                          >
                          </div>
                        </div>
                      </div>
                    </div>
                  </template>
                </uk-lsh>
              </div>
            </div>

            <div class="">
              <button class="uk-button uk-button-primary">
                Update preferences
              </button>
            </div>
          </li>
          <li class="space-y" style={stl({ "--space-y": "6" })}>
            <div>
              <h3 class="text-lg font-medium">Notifications</h3>
              <p
                class="color text-sm"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                Configure how you receive notifications.
              </p>
            </div>

            <div
              class="border-t-w border-t/o"
              style={stl({
                "--border-t-w": "1px",
                "--border-t": "var(--uk-border)",
                "--border-t-o": "var(--uk-border-o)",
              })}
            >
            </div>

            <div class="space-y" style={stl({ "--space-y": "2" })}>
              <div class="uk-form-label">Notify me about</div>
              {
                [
                  "All new messages",
                  "Direct messages and mentions",
                  "Nothing",
                ].map((a, b) => (
                  <label
                    class="display-block text-sm"
                    for={`notification_${b}`}
                  >
                    <input
                      id={`notification_${b}`}
                      class="uk-radio mr"
                      style={stl({ "--mr": "2" })}
                      name="notification"
                      type="radio"
                      checked={a === "Nothing"}
                    />
                    {a}
                  </label>
                ))
              }
            </div>

            <div>
              <h3 class="mb text-lg font-medium" style={stl({ "--mb": "4" })}>
                Email Notifications
              </h3>
              <div class="space-y" style={stl({ "--space-y": "4" })}>
                {
                  [
                    {
                      title: "Communication emails",
                      description:
                        "Receive emails about your account activity.",
                      checked: false,
                      disabled: false,
                    },
                    {
                      title: "Marketing emails",
                      description:
                        "Receive emails about new products, features, and more.",
                      checked: false,
                      disabled: false,
                    },
                    {
                      title: "Social emails",
                      description:
                        "Receive emails for friend requests, follows, and more.",
                      checked: true,
                      disabled: false,
                    },
                    {
                      title: "Security emails",
                      description:
                        "Receive emails about your account activity and security.",
                      checked: true,
                      disabled: true,
                    },
                  ].map((a, b) => (
                    <div
                      class="border-w border/o display-flex items-center justify-between rounded-lg p"
                      style={stl({
                        "--border-w": "1px",
                        "--border": "var(--uk-border)",
                        "--border-o": "var(--uk-border-o)",
                        "--p": "4",
                      })}
                    >
                      <div class="space-y-0.5">
                        <label
                          class="text-base font-medium"
                          for={`email_notification_${b}`}
                        >
                          {a.title}
                        </label>
                        <div
                          class="uk-form-help color"
                          style={stl({ "--color": "var(--uk-muted-f)" })}
                        >
                          {a.description}
                        </div>
                      </div>

                      <input
                        class="uk-toggle-switch uk-toggle-switch-primary"
                        id={`email_notification_${b}`}
                        type="checkbox"
                        checked={a.checked}
                        disabled={a.disabled}
                      />
                    </div>
                  ))
                }
              </div>
            </div>

            <div class="display-flex gap-x" style={stl({ "--gap-x": "3" })}>
              <input
                class="uk-checkbox mt-1"
                id="notification_mobile"
                type="checkbox"
                checked
              />
              <div class="space-y" style={stl({ "--space-y": "1" })}>
                <label
                  class="display-block uk-form-label"
                  for="notification_mobile"
                >
                  Use different settings for my mobile devices
                </label>
                <div
                  class="uk-form-help color"
                  style={stl({ "--color": "var(--uk-muted-f)" })}
                >
                  You can manage your mobile notifications in the mobile
                  settings page.
                </div>
              </div>
            </div>

            <div class="">
              <button class="uk-button uk-button-primary">
                Update notifications
              </button>
            </div>
          </li>

          <li class="space-y" style={stl({ "--space-y": "6" })}>
            <div>
              <h3 class="text-lg font-medium">Display</h3>
              <p
                class="color text-sm"
                style={stl({ "--color": "var(--uk-muted-f)" })}
              >
                Turn items on or off to control what's displayed in the app.
              </p>
            </div>

            <div
              class="border-t-w border-t/o"
              style={stl({
                "--border-t-w": "1px",
                "--border-t": "var(--uk-border)",
                "--border-t-o": "var(--uk-border-o)",
              })}
            >
            </div>

            <div class="space-y" style={stl({ "--space-y": "2" })}>
              <div class="mb" style={stl({ "--mb": "4" })}>
                <span class="text-base font-medium"> Sidebar </span>
                <div
                  class="uk-form-help color"
                  style={stl({ "--color": "var(--uk-muted-f)" })}
                >
                  Select the items you want to display in the sidebar.
                </div>
              </div>
              {
                [
                  "Recents",
                  "Home",
                  "Applications",
                  "Desktop",
                  "Downloads",
                  "Documents",
                ].map((a, b) => (
                  <label class="display-block text-sm" for={`display_${b}`}>
                    <input
                      class="uk-checkbox mr"
                      style={stl({ "--mr": "2" })}
                      type="checkbox"
                      checked={[0, 1, 2].includes(b)}
                    />
                    {a}
                  </label>
                ))
              }
            </div>

            <div class="">
              <button class="uk-button uk-button-primary">
                Update display
              </button>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Frame>
