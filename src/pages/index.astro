---
import Home from "layouts/home.astro";
import Monster from "src/assets/monster.svg";
import Highlighter from "components/highlighter.astro";
import VerticalMacguffin from "components/partials/home/vertical-macguffin.astro";
import HSpacer from "components/partials/home/h-spacer.astro";
import Feature from "components/partials/home/feature.astro";
import Examples from "components/examples.astro";
import { stl } from "helpers/common";
import data from "data/examples";
---

<style is:inline>
  :root {
    --ft-cell-border-color: var(--color-neutral-300);
    --ft-cell-fill-color: var(--color-neutral-100);
    --ft-cell-shadow-color: var(--color-neutral-500);
  }

  .dark {
    --ft-cell-border-color: var(--color-neutral-700);
    --ft-cell-fill-color: var(--color-neutral-900);
    --ft-cell-shadow-color: var(--color-neutral-800);
  }

  .dark .ft-cell {
    box-shadow: inset 0px 0px 40px 1px var(--ft-cell-shadow-color);
  }

  .ft-cell:hover {
    opacity: 0.8;
  }

  @keyframes ft-cell-ripple {
    0% {
      opacity: 0.4;
    }
    50% {
      opacity: 0.8;
    }
    100% {
      opacity: 0.4;
    }
  }
</style>

<Home
  doc={{
    title: "The Frankenstyle Project - A painless frontend system.",
  }}
>
  <div
    class="display-flex relative min-h-screen w-full flex-col items-start justify-start overflow-hidden"
  >
    <div data-ft-bg-ripple-effect></div>

    <div
      class="mt sm:mt md:mt w-full"
      style={stl({
        "--mt": "30",
        "--sm-mt": "40",
        "--md-mt": "60",
      })}
    >
      <div
        class="z relative display-flex justify-center"
        style={stl({ "--z": "10" })}
      >
        <Monster
          id="monster"
          height={128}
          width={128}
          class:list="fill stroke"
          style={stl({
            "--fill": "var(--uk-primary)",
            "--stroke": "var(--uk-primary)",
          })}
        />
      </div>
      <h2
        class="z mt relative mx-auto max-w-4xl text-center text-2xl font-bold md:text-3xl lg:text-6xl"
        style={stl({
          "--z": "10",
          "--mt": "4",
        })}
      >
        Great web development shouldn't be complicated.
      </h2>

      <div
        class="z mt color dark:color relative mx-auto max-w-xl text-center px sm:px"
        style={stl({
          "--z": "10",
          "--mt": "8",
          "--color": "var(--uk-muted-f)",
          "--px": "4",
          "--sm-px": "0",
        })}
      >
        <div class="">
          Built on proven foundations. No overengineering. Extending, not
          replacing.
        </div>
        <div class="">
          The Frankenstyle Project is a full-fledged frontend system. Zero
          setup, no npm, no builds, no watchers.
        </div>
      </div>

      <div
        class="z relative display-flex mt gap-x justify-center px sm:px"
        style={stl({
          "--z": "10",
          "--mt": "8",
          "--gap-x": "2",
          "--px": "4",
          "--sm-px": "0",
        })}
      >
        <a
          class="uk-button uk-button-primary uk-button-large w-full sm:w-auto gap-x"
          style="--gap-x: 2"
          href="/docs/latest/kit/installation"
        >
          Get Started
          <uk-icon class="size" style="--size: 4" icon="arrow-right"></uk-icon>
        </a>

        <button
          class="uk-button uk-button-default uk-button-large display-hidden lg:display-inline-flex gap-x"
          style="--gap-x: 2"
          x-data
          x-on:click={`copyPreview('/hx/boilerplate', 'copy_boilerplate')`}
        >
          <uk-icon class="size" style={stl({ "--size": "4" })} icon="copy"
          ></uk-icon>
          Grab Starter Template
        </button>
      </div>
    </div>

    <div
      class="absolute bottom pb display-flex justify-center w-full"
      style={stl({ "--bottom": "0", "--pb": "8" })}
      x-data="{ show: true }"
      x-init="window.addEventListener('scroll', () => { show = window.scrollY < 200 })"
      x-show="show"
      x-transition.opacity.duration.300ms
    >
      <a
        href="#why-frankenstyle"
        class="animate-bounce uk-button uk-button-default uk-button-icon rounded-full"
        data-uk-scroll
      >
        <uk-icon icon="chevrons-down"></uk-icon>
      </a>
    </div>
  </div>

  <div id="why-frankenstyle" class="relative mt" style={stl({ "--mt": "16" })}>
    <VerticalMacguffin>
      <script is:inline data-fn="props" type="application/json">
        {
          "text": "Why the heck?",
          "revealDelayMs": "150"
        }
      </script>
    </VerticalMacguffin>

    <div class="divider-line">
      <HSpacer>
        <h2 class="uk-h2">Built for the modern web.</h2>

        <div
          class="uk-text-medium [max-w] color mt"
          style={stl({
            "--max-w": "var(--breakpoint-md)",
            "--color": "var(--uk-muted-f)",
            "--mt": "2",
          })}
        >
          Built for the modern web means embracing what already works.
          Frankenstyle embraces modern CSS features to deliver a powerful,
          straightforward frontend system with zero setup.
        </div>
      </HSpacer>
    </div>

    <div class="divider-line mt" style={stl({ "--mt": "16" })}>
      <Feature
        title="Modern Color Palette"
        content="Frankenstyle uses Tailwind CSS's color palette to deliver rich, vibrant colors out of the box. Hit Alt and click to copy the CSS variable."
      />

      <div
        class="bg/o animate-pulse [h] sm:[h]"
        style={stl({
          "--bg": "var(--uk-muted)",
          "--bg-o": "var(--uk-muted-o)",
          "--h": "434px",
          "--sm-h": "522px",
        })}
        hx-get="/hx/partials/showcases/colors"
        hx-swap="outerHTML"
        hx-trigger="intersect"
      >
      </div>

      <div
        class="display-grid grid-cols xl:grid-cols border-t-w border-t/o"
        style={stl({
          "--grid-cols": "1",
          "--xl-grid-cols": "2",
          "--border-t-w": "1px",
          "--border-t": "var(--uk-border)",
          "--border-t-o": "var(--uk-border-o)",
        })}
      >
        <div
          class="border-b-w xl:border-b-w border/o overflow-hidden"
          style={stl({
            "--border-b-w": "1px",
            "--xl-border-b-w": "0px",
            "--border": "var(--uk-border)",
            "--border-o": "var(--uk-border-o)",
          })}
        >
          <Feature
            title="Filters"
            content="Modern CSS filters, including backdrop blur, sepia, grayscale, and more, with zero configuration."
          />

          <div class="py xl:py" style={stl({ "--py": "4", "--xl-py": "0" })}>
            <div
              class="bg/o animate-pulse [h] sm:[h]"
              style={stl({
                "--bg": "var(--uk-muted)",
                "--bg-o": "var(--uk-muted-o)",
                "--h": "282px",
                "--sm-h": "482px",
              })}
              hx-get="/hx/partials/showcases/filters"
              hx-swap="outerHTML"
              hx-trigger="intersect"
            >
            </div>
          </div>
        </div>
        <div
          class="xl:border-l-w border/o"
          style={stl({
            "--xl-border-l-w": "1px",
            "--border": "var(--uk-border)",
            "--border-o": "var(--uk-border-o)",
          })}
        >
          <Feature
            title="Gradients"
            content="Gradient utilities that let you create smooth gradients without complex syntax."
          />
          <div
            class="bg/o animate-pulse [h] sm:[h]"
            style={stl({
              "--bg": "var(--uk-muted)",
              "--bg-o": "var(--uk-muted-o)",
              "--h": "644px",
              "--sm-h": "540px",
            })}
            hx-get="/hx/partials/showcases/gradients"
            hx-swap="outerHTML"
            hx-trigger="intersect"
          >
          </div>
        </div>
      </div>

      <div
        class="border-y-w border-y/o"
        style={stl({
          "--border-y-w": "1px",
          "--border-y": "var(--uk-border)",
          "--border-y-o": "var(--uk-border-o)",
        })}
      >
        <Feature
          title="Dark mode"
          content="Dark mode is standard for modern websites and included out of the box. Prefix any color utilities with dark: to apply it in dark mode."
        />
      </div>

      <div
        class="w-full aspect bg/o animate-pulse"
        style={stl({
          "--bg": "var(--uk-muted)",
          "--bg-o": "var(--uk-muted-o)",
          "--aspect": "1920 / 981",
        })}
        hx-get="/hx/partials/showcases/dark"
        hx-swap="outerHTML"
        hx-trigger="intersect"
      >
      </div>
    </div>
  </div>

  <div id="how-it-works" class="relative mt" style={stl({ "--mt": "24" })}>
    <VerticalMacguffin>
      <script is:inline data-fn="props" type="application/json">
        {
          "text": "How it works?",
          "revealDelayMs": "150"
        }
      </script>
    </VerticalMacguffin>

    <div class="divider-line">
      <HSpacer>
        <h2 class="uk-h2">The Basics</h2>

        <div
          class="uk-text-medium [max-w] color mt"
          style={stl({
            "--max-w": "var(--breakpoint-md)",
            "--color": "var(--uk-muted-f)",
            "--mt": "2",
          })}
        >
          Frankenstyle is a no-build, value-driven CSS framework. Drop in a
          single stylesheet and start building immediately.
        </div>
      </HSpacer>
    </div>

    <div
      class="divider-line mt py sm:py"
      style={stl({ "--mt": "16", "--py": "4", "--sm-py": "2" })}
    >
      <HSpacer>
        <div data-uk-scrollspy="cls: uk-animation-fade">
          <Highlighter path="how-it-works-demo.html" type={true} />
        </div>
      </HSpacer>
    </div>
  </div>

  <div id="get-the-kit" class="relative mt" style={stl({ "--mt": "24" })}>
    <VerticalMacguffin>
      <script is:inline data-fn="props" type="application/json">
        {
          "text": "Get the Kit.",
          "revealDelayMs": "150"
        }
      </script>
    </VerticalMacguffin>

    <div class="divider-line">
      <HSpacer>
        <h2 class="uk-h2">
          Do more with <span class="sm:display-hidden">the Kit.</span>
          <span class="display-hidden sm:display-inline">FrankenstyleKit.</span>
        </h2>

        <div
          class="uk-text-medium [max-w] color mt"
          style={stl({
            "--max-w": "var(--breakpoint-md)",
            "--color": "var(--uk-muted-f)",
            "--mt": "2",
          })}
        >
          FrankenstyleKit is an HTML-first UI component library built on UIkit 3
          and extended with LitElement, inspired by coss ui.
        </div>
      </HSpacer>
    </div>

    <div class="divider-line mt py" style={stl({ "--mt": "16", "--py": "2" })}>
      <HSpacer>
        <ul
          class="mt mb uk-subnav uk-subnav-primary justify-center"
          style={stl({
            "--mt": "2",
            "--mb": "4",
          })}
          data-uk-switcher
        >
          {
            data.map((a, b) => (
              <li class={b === 1 ? "uk-active" : ""}>
                <a
                  class="cursor-pointer"
                  hx-get={`/hx/examples/${a.slug}`}
                  hx-target="#example"
                  hx-swap="outerHTML"
                >
                  {a.title}
                </a>
              </li>
            ))
          }
        </ul>
        <Examples active="example-02" />
      </HSpacer>
    </div>
  </div>

  <div id="how-it-works" class="relative mt" style={stl({ "--mt": "24" })}>
    <VerticalMacguffin>
      <script is:inline data-fn="props" type="application/json">
        {
          "text": "Hire a Human",
          "revealDelayMs": "150"
        }
      </script>
    </VerticalMacguffin>

    <div class="divider-line p" style={{ "--p": "2" }}>
      <div
        class="display-flex relative min-h w-full flex-col items-start justify-start overflow-hidden"
      >
        <div data-ft-bg-ripple-effect></div>

        <div
          class="mt sm:mt md:mt w-full"
          style={stl({
            "--min-h": "128",
            "--mt": "30",
            "--sm-mt": "40",
            "--md-mt": "60",
          })}
        >
          <h2
            class="z relative mx-auto max-w-4xl text-center text-2xl font-bold md:text-3xl lg:text-6xl"
            style={stl({
              "--z": "10",
            })}
          >
            <div data-ft-text-encrypted>
              <script is:inline data-fn="props" type="application/json">
                {
                  "text": "Need some help?",
                  "revealDelayMs": "150"
                }
              </script>
            </div>
          </h2>

          <div
            class="z mt color dark:color relative mx-auto max-w-xl text-center px sm:px"
            style={stl({
              "--z": "10",
              "--mt": "8",
              "--color": "var(--uk-muted-f)",
              "--px": "4",
              "--sm-px": "0",
            })}
          >
            <div class="">
              We built it. We maintain it. We can help you use it.
            </div>
            <div class="">
              Hire the pros behind the project and skip the guesswork.
            </div>
          </div>

          <div
            class="z relative display-flex mt gap-x justify-center px sm:px pb"
            style={stl({
              "--z": "10",
              "--mt": "8",
              "--gap-x": "2",
              "--px": "4",
              "--sm-px": "0",
              "--pb": "4",
            })}
          >
            <a
              class="uk-button uk-button-primary uk-button-large w-full sm:w-auto gap-x"
              style="--gap-x: 2"
              href="mailto:reden@franken-ui.dev"
              id="get-in-touch"
            >
              Get in Touch
              <uk-icon class="size" style="--size: 4" icon="mail"></uk-icon>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div
    class="relative mt px display-flex justify-center"
    style={stl({ "--mt": "24", "--px": "2" })}
  >
    <div class="">
      <span class="color" style={stl({ "--color": "var(--uk-muted-f)" })}>
        &copy; 2026
      </span>
      <span class="font-bold">FRNKN Creatives</span>
      <span class="color" style={stl({ "--color": "var(--uk-muted-f)" })}>
        – keep it simple, seriously.
      </span>
    </div>
  </div>

  <script is:inline>
    const getInTouch = document.getElementById("get-in-touch");

    if (getInTouch) {
      getInTouch.addEventListener("click", () => {
        if (window.zaraz) {
          window.zaraz.track("home_get_in_touch_clicked");
        }
      });
    }
  </script>
</Home>
