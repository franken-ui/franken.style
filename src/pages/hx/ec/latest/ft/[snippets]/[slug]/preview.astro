---
import type { GetStaticPaths } from "astro";
import { getSnippetPaths } from "data/snippets/base";
import Ft from "layouts/ft.astro";

export const getStaticPaths = (async () =>
  getSnippetPaths({
    version: "latest",
    project: "ft",
  })) satisfies GetStaticPaths;

const { content, category } = Astro.props;

const urls: { [key: string]: any } = {
  animated_testimonials:
    "https://cdn.jsdelivr.net/npm/frankenstyle@0.3.3/dist/js/ft/animated-testimonials.iife.js",
  bg_beams:
    "https://cdn.jsdelivr.net/npm/frankenstyle@0.3.3/dist/js/ft/bg-beams.iife.js",
  bg_boxes:
    "https://cdn.jsdelivr.net/npm/frankenstyle@0.3.3/dist/js/ft/bg-boxes.iife.js",
  bg_lines:
    "https://cdn.jsdelivr.net/npm/frankenstyle@0.3.3/dist/js/ft/bg-lines.iife.js",
  sparkles:
    "https://cdn.jsdelivr.net/npm/frankenstyle@0.3.3/dist/js/ft/sparkles.iife.js",
  text_encrypted:
    "https://cdn.jsdelivr.net/npm/frankenstyle@0.3.3/dist/js/ft/text-encrypted.iife.js",
  text_hover_effect:
    "https://cdn.jsdelivr.net/npm/frankenstyle@0.3.3/dist/js/ft/text-hover-effect.iife.js",
  text_reveal_card:
    "https://cdn.jsdelivr.net/npm/frankenstyle@0.3.3/dist/js/ft/text-reveal-card.iife.js",
  bg_ripple_effect:
    "https://cdn.jsdelivr.net/npm/frankenstyle@0.3.3/dist/js/ft/bg-ripple-effect.iife.js",
};
---

<Ft doc={{ title: category }}>
  <Fragment set:html={content} />

  <script is:inline src={urls[category]}></script>
</Ft>
