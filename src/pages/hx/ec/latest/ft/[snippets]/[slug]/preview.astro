---
import type { GetStaticPaths } from "astro";
import { getSnippetPaths } from "data/snippets/base";
import Ft from "layouts/ft.astro";

import animated_testimonials from "frankenstyle/js/ft/animated-testimonials.iife?url";
import bg_beams from "frankenstyle/js/ft/bg-beams.iife?url";
import bg_boxes from "frankenstyle/js/ft/bg-boxes.iife?url";
import bg_lines from "frankenstyle/js/ft/bg-lines.iife?url";
import sparkles from "frankenstyle/js/ft/sparkles.iife?url";
import text_encrypted from "frankenstyle/js/ft/text-encrypted.iife?url";
import text_hover_effect from "frankenstyle/js/ft/text-hover-effect.iife?url";
import text_reveal_card from "frankenstyle/js/ft/text-reveal-card.iife?url";

export const getStaticPaths = (async () =>
  getSnippetPaths({
    version: "latest",
    project: "ft",
  })) satisfies GetStaticPaths;

const { content, category } = Astro.props;

const urls: { [key: string]: any } = {
  animated_testimonials,
  bg_beams,
  bg_boxes,
  bg_lines,
  sparkles,
  text_encrypted,
  text_hover_effect,
  text_reveal_card,
};
---

<Ft doc={{ title: category }}>
  <Fragment set:html={content} />

  <script is:inline src={urls[category]}></script>
</Ft>
